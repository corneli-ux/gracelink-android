<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network for streaming + API -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Background audio + foreground service (will be re-enabled when
         GraceLinkMediaService is implemented in Phase 1.5). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Downloads use scoped storage via MediaStore / app-specific dirs.
         No WRITE_EXTERNAL_STORAGE needed since minSdk = 26 and we target 35. -->

    <application
        android:name=".GraceLinkApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.GraceLink.Splash"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.GraceLink.Splash"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|uiMode|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Background playback service will be declared here once we ship a
            concrete GraceLinkMediaService subclass that extends Media3's
            MediaSessionService. The base class is abstract and CANNOT be
            instantiated directly by Android, so we don't declare it yet.
        -->
    </application>

</manifest>
