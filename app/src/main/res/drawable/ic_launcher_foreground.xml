<?xml version="1.0" encoding="utf-8"?>
<!--
    GraceLink launcher icon — a stylized gold cross + sound wave on deep slate.
    The cross is the brand's primary symbol; the wave represents radio/audio.
    Designed to read clearly at 48dp (smallest display) and pixel-perfect at 192dp.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Cross (gold) -->
    <group android:scaleX="0.55" android:scaleY="0.55" android:translateX="24.3" android:translateY="22.0">
        <!-- Vertical bar -->
        <path
            android:fillColor="#F59E0B"
            android:pathData="M48,16 L60,16 L60,40 L84,40 L84,52 L60,52 L60,92 L48,92 L48,52 L24,52 L24,40 L48,40 Z"/>
    </group>

    <!-- Sound waves on the right -->
    <group android:scaleX="1" android:scaleY="1">
        <path
            android:strokeColor="#10B981"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:pathData="M70,54 Q78,54 78,62 Q78,70 70,70"/>
        <path
            android:strokeColor="#10B981"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:pathData="M76,48 Q88,52 88,62 Q88,72 76,76"/>
        <path
            android:strokeColor="#10B981"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:pathData="M82,42 Q98,49 98,62 Q98,75 82,82"/>
    </group>
</vector>
