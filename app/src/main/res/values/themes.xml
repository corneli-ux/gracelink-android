<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Launch theme — dark background to avoid white flash on cold start.
        Uses android:Theme.DeviceDefault.NoActionBar which is always available
        on API 26+ and provides a dark window background by default.
    -->
    <style name="Theme.GraceLink.Splash" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/grace_background</item>
        <item name="android:statusBarColor">@color/grace_background</item>
        <item name="android:navigationBarColor">@color/grace_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Main Compose theme — this is just a shell; real theming lives in Compose. -->
    <style name="Theme.GraceLink" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@color/grace_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
