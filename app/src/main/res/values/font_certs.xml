<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Certificates for the Google Fonts provider — these are well-known public
        signing certs for the GMS Fonts service. Required by Compose's
        GoogleFont provider when fetching Inter / Lora at runtime.
        Source: https://developers.google.com/fonts/docs/android
    -->
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>
